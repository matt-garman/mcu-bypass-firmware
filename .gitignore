# vim backup files
*~

# compilation artifacts
*.hex
*.elf
build_avr_classic/
build_pic/
build_avr_xt/

# vendored ATtiny_DFP device files for the ATtiny202 (AVR-XT) build -- fetched
# on demand by scripts/fetch_attiny_dfp.sh (pinned version + SHA), NOT committed,
# mirroring the external/uncommitted PIC_DFP. Override the location with XT_DFP.
# NOTE: ignore the CONTENTS (third_party/*), not the directory itself
# (third_party/), so the negations below can re-include specific files -- git
# will not descend into a directory excluded with a trailing slash.
third_party/*

# ...EXCEPT the yasimavr upstream-bug patches, which ARE tracked: they are the
# source of truth for scripts/fetch_yasimavr.sh (which builds the patched
# yasimavr venv used by the attiny202-{sim,soak,fault} harness). The venv it
# produces IS a generated artifact and stays ignored. Same escape as release/**.
!third_party/yasimavr/
third_party/yasimavr/venv/

# ...EXCEPT the prebuilt release images, which ARE tracked: committing them is
# the whole point of release/ (scripts/make-release.sh stages them there). The
# global *.hex ignore above would otherwise silently drop them from `git add`.
!release/**/*.hex

# cppcheck addon artifacts (e.g. "make analyze-misra"); normally auto-cleaned,
# but a cancelled run can leave them behind
*.dump
*.ctu-info
cppcheck-addon-ctu-file-list*

# gpsim drops this log (often 0-byte) in the cwd on every `make pic-test-soak`
gpsim.log

# coverage artifacts (generated by "make coverage")
coverage/

# clade code
.claude/
