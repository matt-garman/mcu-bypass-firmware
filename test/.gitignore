# Compiled test binaries live next to their sources in per-substrate subdirs.
host/test_logic_host
formal/test_model_check
formal/test_symbolic
formal/test_symbolic.bc
avr/test_fuses
avr/test_soak_*5
pic/test_config_pic
pic/test_soak_pic
pic/test_fault_pic
# per-variant simavr harnesses: test_sim_<variant>[_t85], test_trace_<variant>
avr/test_sim
avr/test_sim_*
avr/test_trace_*
# ...but the yasimavr harness DRIVERS are Python source, not compiled binaries:
# keep every avr/*.py tracked even though names like test_sim_attiny202.py would
# otherwise match the compiled-binary globs above. Only the bytecode cache is
# ignored.
!avr/*.py
avr/__pycache__/

# KLEE output and the toolchain stamp are produced at the test root.
klee-last
klee-out-*/
.toolchain.sig
